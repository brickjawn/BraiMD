<%- include('partials/header') %>

<div class="max-w-4xl">
  <!-- Header -->
  <div class="flex items-start justify-between mb-4">
    <div>
      <h1 class="text-2xl font-bold"><%= skill.name %></h1>
      <% if (skill.description) { %>
        <p class="text-slate-400 mt-1"><%= skill.description %></p>
      <% } %>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <a href="/dashboard/skills/<%= skill.id %>/edit" class="bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors">
        <i class="fa-solid fa-pen-to-square mr-1"></i> Edit
      </a>
      <form action="/dashboard/skills/<%= skill.id %>/delete" method="POST" class="inline"
            onsubmit="return confirm('Delete this skill permanently?')">
        <button type="submit" class="bg-rose-900/50 hover:bg-rose-800 text-rose-300 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors">
          <i class="fa-solid fa-trash mr-1"></i> Delete
        </button>
      </form>
    </div>
  </div>

  <!-- Trigger badges -->
  <div class="flex flex-wrap gap-1.5 mb-6">
    <% const triggers = typeof skill.triggers === 'string' ? JSON.parse(skill.triggers) : (skill.triggers || []); %>
    <% triggers.forEach(t => { %>
      <span class="bg-indigo-500/20 text-indigo-300 text-xs px-2.5 py-1 rounded-full"><%= t %></span>
    <% }) %>
  </div>

  <!-- Tab navigation -->
  <div class="flex border-b border-slate-800 mb-4 gap-1" role="tablist">
    <button class="tab-btn px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-indigo-500 text-indigo-400 bg-slate-900/50" data-tab="rendered">Rendered</button>
    <button class="tab-btn px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-slate-400 hover:text-slate-200" data-tab="raw">Raw Markdown</button>
    <button class="tab-btn px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-slate-400 hover:text-slate-200" data-tab="split">Split View</button>
  </div>

  <!-- Tab panels -->
  <div id="tab-rendered" class="tab-panel">
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 prose prose-invert max-w-none prose-pre:bg-slate-800 prose-code:text-indigo-300">
      <%- renderedHtml %>
    </div>
  </div>

  <div id="tab-raw" class="tab-panel hidden">
    <pre class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-sm text-slate-300 font-mono whitespace-pre-wrap overflow-x-auto"><%= skill.content %></pre>
  </div>

  <div id="tab-split" class="tab-panel hidden">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <h6 class="text-xs font-medium text-slate-500 mb-2 uppercase tracking-wider">Raw Markdown</h6>
        <pre class="bg-slate-900 border border-slate-800 rounded-xl p-4 text-sm text-slate-300 font-mono whitespace-pre-wrap overflow-x-auto h-[600px] overflow-y-auto"><%= skill.content %></pre>
      </div>
      <div>
        <h6 class="text-xs font-medium text-slate-500 mb-2 uppercase tracking-wider">Rendered HTML</h6>
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 prose prose-invert prose-sm max-w-none h-[600px] overflow-y-auto prose-pre:bg-slate-800 prose-code:text-indigo-300">
          <%- renderedHtml %>
        </div>
      </div>
    </div>
  </div>

  <a href="/dashboard" class="inline-block mt-6 text-slate-400 hover:text-slate-300 text-sm">&larr; Back to Dashboard</a>
</div>

<script>
  // Tab switching logic
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('border-indigo-500', 'text-indigo-400', 'bg-slate-900/50');
        b.classList.add('border-transparent', 'text-slate-400');
      });
      btn.classList.add('border-indigo-500', 'text-indigo-400', 'bg-slate-900/50');
      btn.classList.remove('border-transparent', 'text-slate-400');
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById('tab-' + btn.dataset.tab).classList.remove('hidden');
    });
  });
</script>

<%- include('partials/footer') %>
