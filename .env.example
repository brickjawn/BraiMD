# =============================================================================
# BraiMD Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# IMPORTANT: .env must have 600 permissions and is gitignored — never commit it.
# =============================================================================

# -- MySQL Connection (must match docker-compose.yml environment block) --------
DB_HOST=127.0.0.1                   # host networking mode for rootless Podman
DB_PORT=3306
DB_USER=braimd
DB_PASSWORD=your_db_password_here
DB_NAME=braimd_db
DB_ROOT_PASSWORD=your_root_password_here

# -- Express Server ------------------------------------------------------------
PORT=3000
CORS_ORIGIN=http://localhost:3000   # lock CORS to your dashboard origin

# -- API Key Auth --------------------------------------------------------------
# The agent-facing /api/skills routes require an x-api-key header.
# Generate a key:    openssl rand -hex 32
# Hash it (SHA-256): echo -n "YOUR_KEY" | sha256sum | awk '{print $1}'
# Store the HASH here (never the raw key):
API_KEY_HASH=
API_KEY_ID=braimd-default           # friendly name logged in agent_logs.agent_id
